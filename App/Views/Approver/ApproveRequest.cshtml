@using App.Models
@using App.Shared
@model Paginated<ApproveRequestDto>
@{
    ViewData["Title"] = "Approve Requests Page";
}

<div class="text-center">
    <br />
    <div class="table-container">
        <h1>Approve Requests</h1>
        <table>
            <thead>
                <tr>
                    <th>Dataset Requested</th>
                    <th>User</th>
                    <th>Reason</th>
                    <th>Date Requested</th>
                    <th colspan="2">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model.Items)
                {
                    <tr>
                        <td>@request.Title</td>
                        <td>@request.Username</td>
                        <td>@request.Reason</td>
                        <td>@request.Timestamp</td>

                        <td>
                            <form asp-action="ApproveRequest" method="post">
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <button type="submit" class="input-button">Approve</button>
                            </form>
                        </td>

                        <td>
                            <form asp-action="DenyRequest" method="get">
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <button type="submit" class="deny-button">Deny</button>
                                        </form>
                                    </td>
                                </tr>

                }
            </tbody>
        </table>
    <div class=" pagination">
                                @if (Model.CurrentPage > 1)
                                {
                                    <a asp-action="Requests" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                                }

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    if (i == Model.CurrentPage)
                                    {
                                        <strong>@i</strong>
                                    }
                                    else
                                    {
                                        <a asp-action="Requests" asp-route-page="@i">@i</a>

                                    }
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <a asp-action="Requests" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                                }
    </div>
</div>
</div>